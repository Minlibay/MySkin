# SMSC.ru credentials. Empty values = DEV mode (codes printed to stdout).
SMSC_LOGIN=
SMSC_PASSWORD=

# Backend HTTP port.
PORT=8080

# CORS — comma-separated whitelist of origins allowed to call the API.
# Use "*" for local dev. For prod use explicit Punycode form of мойскин.рф:
CORS_ALLOWED_ORIGINS=https://admin.xn--80allhkb1j.xn--p1ai

# PostgreSQL — matches docker-compose.yml defaults.
DATABASE_URL=postgres://myskin:myskin@localhost:15432/myskin

# Salt for OTP hashing. Change once and never rotate (existing OTPs would break).
OTP_PEPPER=change-me-to-a-random-string

# GigaChat (Sber). Get key at developers.sber.ru. Empty = mock AI is used.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Qwen (Alibaba DashScope). Get key at dashscope.console.aliyun.com/apiKey.
# Empty = Qwen provider is not available; admin can only pick GigaChat.
# International region (default) works from RF without VPN.
DASHSCOPE_API_KEY=
QWEN_CHAT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-max
# Override only if you need the China region (lower latency from CIS but
# blocked in some networks):
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Seed admin (used by `dart run bin/seed_admin.dart`).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
