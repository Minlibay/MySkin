# MySkin reverse proxy.
#
# Replace example.com with your real domain. Caddy will auto-issue and
# auto-renew SSL certs from Let's Encrypt as long as DNS A-records point at
# the server.
#
# DNS setup (in your registrar):
#   api.example.com     A  <vps-ip>
#   admin.example.com   A  <vps-ip>
#   app.example.com     A  <vps-ip>     (optional — for the Flutter web app)

api.example.com {
    encode zstd gzip
    reverse_proxy backend:8080
    request_body {
        # Photos can be up to ~6MB after base64 inflation.
        max_size 10MB
    }
}

admin.example.com {
    encode zstd gzip
    reverse_proxy admin:80
}

# Optional: serve the Flutter web app from somewhere.
# app.example.com {
#     root * /srv/myskin-web
#     try_files {path} /index.html
#     file_server
# }

# HTTP → HTTPS redirect happens automatically.
