# MySkin reverse proxy — мойскин.рф (Punycode form for SSL/Caddy).
#
# DNS setup in registrar (укажи кириллицей или Punycode — конвертится автоматом):
#   api.мойскин.рф    A  <vps-ip>     (api.xn--80allhkb1j.xn--p1ai)
#   admin.мойскин.рф  A  <vps-ip>     (admin.xn--80allhkb1j.xn--p1ai)
#
# Caddy получит SSL от Let's Encrypt автоматически на Punycode-имена,
# браузер отобразит как кириллицу.

api.xn--80allhkb1j.xn--p1ai {
    encode zstd gzip
    reverse_proxy backend:8080
    request_body {
        # Photos can be up to ~6MB after base64 inflation.
        max_size 10MB
    }
}

admin.xn--80allhkb1j.xn--p1ai {
    encode zstd gzip
    reverse_proxy admin:80
}

# partner.моякожа.рф — partner SPA. Caddy 2 accepts raw IDN in the site
# address and converts to punycode internally, so we keep the human form
# to avoid Punycode-mismatch bugs.
partner.моякожа.рф {
    encode zstd gzip
    reverse_proxy partner:80
}

# HTTP → HTTPS redirect happens automatically.
