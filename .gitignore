**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets — never commit
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Caddy data (issued certs, not for git)
caddy-data/
caddy-config/

# Design handoff bundle (received via WebFetch, not for git)
.design_handoff/

# Node / Vite (admin)
node_modules/
admin/dist/
admin/.vite/

# Backend Dart build artifacts
backend/.dart_tool/
backend/build/
backend/.packages

# iOS / native build outputs
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
android/.gradle/
android/local.properties
android/app/release/
android/app/profile/
android/app/debug/

