# Top-level env consumed by docker-compose. For local dev, copy to .env
# and tweak. For prod, set proper secrets and CORS.

# ===== Postgres =====
POSTGRES_USER=myskin
POSTGRES_PASSWORD=myskin            # change for prod
POSTGRES_DB=myskin

# ===== Backend =====
OTP_PEPPER=change-me-to-a-random-string
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin                # change for prod, then re-run seed_admin

# Comma-separated origins. Use "*" only in local dev.
# Prod values for мойскин.рф (Punycode):
CORS_ALLOWED_ORIGINS=https://admin.xn--80allhkb1j.xn--p1ai

# ===== SMSC.ru =====
# Empty values keep the backend in DEV mode (codes printed to stdout).
SMSC_LOGIN=
SMSC_PASSWORD=

# ===== GigaChat =====
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ===== Admin web build =====
# URL the admin SPA should call.
PUBLIC_BACKEND_URL=https://api.xn--80allhkb1j.xn--p1ai
